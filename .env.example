# ---------------------------------------------------------------
# TrustOS pilot — environment template
# Copy to .env for local development. NEVER commit .env.
#
# NOTE: This application uses custom JWT authentication built on
# `jose`. It does NOT use NextAuth. The AUTH_SECRET variable is a
# plain HS256 signing key, not a NextAuth secret.
# ---------------------------------------------------------------

# REQUIRED — PostgreSQL connection string (Neon, Supabase, local)
# Neon format: postgresql://user:password@host.neon.tech/db?sslmode=require
DATABASE_URL=""

# REQUIRED — JWT signing key. Generate with: openssl rand -base64 32
# Must be set in the Netlify BUILD environment as well as runtime.
# There is no fallback. NEXTAUTH_SECRET is no longer read.
AUTH_SECRET=""

# REQUIRED — Public base URL of this deployment (no trailing slash)
APP_URL="http://localhost:3000"

# OPTIONAL — Stripe test mode. Payments are disabled if unset.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# SEED ONLY — all four required by `npm run db:seed`, which throws if
# any is absent. Set them on the seed command only. Do NOT add to Netlify.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_VENDOR_EMAIL=""
SEED_VENDOR_PASSWORD=""

# OPTIONAL — exposes /api/health detail to requests carrying this token
HEALTH_TOKEN=""
